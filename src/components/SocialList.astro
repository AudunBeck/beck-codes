  },
  {
    key: "linkedin",
    friendlyName: "LinkedIn",
    link: "https://www.linkedin.com/in/audun-beck",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path d="M0 0h24v24H0z" fill="none"/><circle cx="4" cy="4" r="2" fill="currentColor"/><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="4"><g stroke-dasharray="12" stroke-dashoffset="12"><path d="M4 10v10" stroke-dashoffset="0"/><path d="M10 10v10" stroke-dashoffset="0"/></g><path d="M10 15c0 -2.76 2.24 -5 5 -5c2.76 0 5 2.24 5 5v5"/></g></svg>`,
